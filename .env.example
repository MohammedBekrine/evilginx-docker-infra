# ============================================
# Evilginx Docker Infrastructure - Config
# Copy to .env and fill in your engagement values
# ============================================

# --- Server ---
SERVER_IP=0.0.0.0
# Where scanners/bots/unauthorized requests get redirected (maps to `config unauth_url`)
REDIRECT_URL=https://www.microsoft.com

# --- Domain ---
BASE_DOMAIN=example.com

# --- Phishlet ---
# PHISHLET_NAME must match a .yaml file that gets loaded into the container.
# Upstream evilginx2 v3.3.0 ships only "example" as a template — it won't
# capture real credentials. For real engagements, drop community phishlets
# (o365, gmail, github, etc.) into ./config/phishlets/ as <name>.yaml and
# set PHISHLET_NAME to that <name>.
PHISHLET_NAME=example
PHISHLET_HOSTNAME=login.example.com

# --- Lure ---
LURE_REDIRECT_URL=https://www.office.com
LURE_PATH=

# --- DNS Provider (Cloudflare) ---
CF_API_TOKEN=
CF_ZONE_ID=

# --- Blacklist ---
BLACKLIST_MODE=unauth
